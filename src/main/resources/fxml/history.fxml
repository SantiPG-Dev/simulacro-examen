<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.examenes.controller.HistoryController"
      spacing="10" styleClass="root">

    <padding>
        <Insets top="15" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Historial de Resultados" styleClass="title"/>

    <Label fx:id="summaryLabel" styleClass="status-label"/>

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateCol" text="Fecha" prefWidth="150"/>
            <TableColumn fx:id="subjectCol" text="Asignatura" prefWidth="150"/>
            <TableColumn fx:id="correctCol" text="Aciertos" prefWidth="80"/>
            <TableColumn fx:id="incorrectCol" text="Fallos" prefWidth="80"/>
            <TableColumn fx:id="blankCol" text="Sin responder" prefWidth="100"/>
            <TableColumn fx:id="scoreCol" text="Nota" prefWidth="80"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Volver al Menu" onAction="#handleBack" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="clearButton" text="Limpiar Historial"
                onAction="#handleClear" styleClass="danger-button" prefWidth="150"/>
    </HBox>

</VBox>
