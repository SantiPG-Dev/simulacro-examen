<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import com.examenes.util.ThemeToggle?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.examenes.controller.MenuController"
      spacing="15" alignment="CENTER" styleClass="root">

    <padding>
        <Insets top="15" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Simulacros de Examen" styleClass="title"/>

    <Label text="Preparate para tus examenes con simulacros personalizados"
           styleClass="subtitle" wrapText="true"/>

    <Region prefHeight="40"/>

    <Button text="Iniciar Simulacro" onAction="#handleStart"
            maxWidth="360" prefHeight="48" styleClass="primary-button"/>

    <Button text="Importar Datos" onAction="#handleImport"
            maxWidth="360" prefHeight="48"/>

    <Button text="Exportar Datos" onAction="#handleExport"
            maxWidth="360" prefHeight="48"/>

    <Button text="Configuracion" onAction="#handleConfig"
            maxWidth="360" prefHeight="48" styleClass="secondary-button"/>

    <Region prefHeight="20"/>

    <Label fx:id="statusLabel" wrapText="true" styleClass="status-label"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <ThemeToggle fx:id="themeToggle"/>
    </HBox>

</VBox>
