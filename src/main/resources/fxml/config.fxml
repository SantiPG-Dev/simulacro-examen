<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.examenes.controller.ConfigController"
      spacing="15" alignment="TOP_CENTER" styleClass="root">

    <padding>
        <Insets top="15" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Configuracion" styleClass="title"/>

    <Region prefHeight="20"/>

    <VBox spacing="8" maxWidth="450">
        <Label text="Carpeta de archivos HTML" styleClass="config-label"/>
        <HBox spacing="8">
            <TextField fx:id="htmlFolderField" maxWidth="450" HBox.hgrow="ALWAYS"/>
            <Button text="Examinar..." onAction="#handleBrowseHtml" styleClass="small-button"/>
        </HBox>
    </VBox>

    <VBox spacing="8" maxWidth="450">
        <Label text="Carpeta de descargas" styleClass="config-label"/>
        <HBox spacing="8">
            <TextField fx:id="downloadsFolderField" maxWidth="450" HBox.hgrow="ALWAYS"/>
            <Button text="Examinar..." onAction="#handleBrowseDownloads" styleClass="small-button"/>
        </HBox>
    </VBox>

    <Separator maxWidth="450"/>

    <VBox spacing="8" maxWidth="450">
        <Label text="Repositorio GitHub (usuario/repo)" styleClass="config-label"/>
        <TextField fx:id="githubRepoField" maxWidth="450" promptText="ej: SantiPG-Dev/simulacro-examen"/>
    </VBox>

    <VBox spacing="8" maxWidth="450">
        <Label text="Token GitHub (opcional)" styleClass="config-label"/>
        <PasswordField fx:id="githubTokenField" maxWidth="450"/>
    </VBox>

    <Region prefHeight="20"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Guardar" onAction="#handleSave" styleClass="primary-button" prefHeight="40" prefWidth="160"/>
        <Button text="Volver" onAction="#handleBack" prefHeight="40" prefWidth="160"/>
    </HBox>

    <Label fx:id="statusLabel" wrapText="true" styleClass="status-label"/>

</VBox>
