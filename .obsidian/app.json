{
  "alwaysUpdateLinks": true,
  "attachmentFolderPath": "assets",
  "newFileLocation": "current",
  "newLinkFormat": "relative",
  "showUnsupportedFiles": true,
  "useMarkdownLinks": true,
  "readableLineLength": false,
  "strictLineBreaks": true,
  "showFrontmatter": true,
  "showIndentGuide": true,
  "autoPairMarkdown": true,
  "smartIndentList": true,
  "focusNewTab": true,
  "tabSize": 4,
  "showLineNumber": true,
  "spellcheck": true,
  "spellcheckLanguages": ["es-ES", "en-US"],
  "communityPluginSortOrder": "download",
  "pluginEnabledStatus": {
    "file-explorer": true,
    "global-search": true,
    "switcher": true,
    "graph": true,
    "backlink": true,
    "outgoing-link": true,
    "tag-pane": true,
    "page-preview": true,
    "daily-notes": false,
    "templates": true,
    "note-composer": true,
    "command-palette": true,
    "starred": true,
    "markdown-importer": false,
    "zk-prefixer": false,
    "random-note": false,
    "outline": true,
    "word-count": true,
    "slides": false,
    "audio-recorder": false,
    "open-with-default-app": false,
    "workspaces": true,
    "file-recovery": true,
    "publish": false,
    "sync": false
  }
}
